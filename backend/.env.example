# Copie este arquivo para .env e preencha com valores reais.
# NUNCA cometa o arquivo .env de verdade no Git.

ENVIRONMENT=development

# Gere com: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=sua-chave
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Gere com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOTP_ENCRYPTION_KEY=sua-chave

# Domínio(s) do frontend publicado, separados por vírgula (sem barra final)
ALLOWED_ORIGINS=http://localhost:5500,https://seu-app.netlify.app

# Supabase (Project Settings > API)
SUPABASE_URL=https://supabase.co
SUPABASE_SERVICE_KEY=sua-service-role-key

# Groq (https://console.groq.com) — usado para transcrição de áudio (Whisper free tier)
GROQ_API_KEY=sua-chave
GROQ_WHISPER_MODEL=whisper-large-v3

# OpenRouter (https://openrouter.ai) — usado para chat e descrição de imagem (modelos :free)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_CHAT_MODEL=meta-llama/llama-3.1-8b-instruct:free
LLM_VISION_MODEL=meta-llama/llama-3.2-11b-vision-instruct:free

EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2

MAX_UPLOAD_SIZE_MB=15
ALLOWED_AUDIO_TYPES=audio/webm,audio/mpeg,audio/wav,audio/ogg,audio/mp4
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp
ALLOWED_VIDEO_TYPES=video/webm,video/mp4,video/quicktime

RATE_LIMIT_CHAT=20/minute
RATE_LIMIT_MEDIA=10/minute
RATE_LIMIT_AUTH=5/minute
